generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mail {
  id          Int      @id @default(autoincrement())
  idUser      String
  orderNumber Int
  orderValue  Float
  mailTo      String
  subject     String
  body        String
  createdAt   DateTime @default(now())
}